{
    // ---------- 格式化 ----------
    // 保存时候格式化
    "editor.formatOnSave": true,
    // 保存用 Prettier 格式化
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    // prettier存在的时候才生效
    "prettier.requireConfig": true,
    // ---------- 文件嵌套 ----------
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "tsconfig.json": "tsconfig.*.json, env.d.ts, typed-router.d.ts",
        "vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*",
        "package.json": "package-lock.json, pnpm*, .yarnrc*, yarn*, .eslint*, eslint*, .oxlint*, oxlint*, .oxfmt*, .prettier*, prettier*, .editorconfig, .gitignore, .gitattributes, mise*.toml"
    }
}